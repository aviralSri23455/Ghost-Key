# Frontend
VITE_API_BASE_URL=http://localhost:4000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://ghostkey-api

# Backend
API_PORT=4000
FRONTEND_ORIGIN=http://localhost:8080
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth0 backend app / M2M
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-backend-client-id
AUTH0_CLIENT_SECRET=your-backend-client-secret
AUTH0_AUDIENCE=https://ghostkey-api
AUTH0_MANAGEMENT_AUDIENCE=https://your-tenant.auth0.com/api/v2/
AUTH0_CALLBACK_URL=http://localhost:4000/auth/callback
AUTH0_LOGOUT_URL=http://localhost:8080/
AUTH0_CIBA_MODE=browser

# AI agent proxy
AI_GATEWAY_API_KEY=your-ai-gateway-key
